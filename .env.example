# Server-side: Gemini API (balance sheet + GST analysis)
GEMINI_API_KEY="your_gemini_api_key_here"

# CORS: comma-separated frontend URLs allowed to call the API (set on Railway/Render)
ALLOWED_ORIGIN="https://your-app.vercel.app"

# Client-side: Supabase (defaulter search)
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your_supabase_anon_key_here"

# Production: Railway/Render API URL (set in Vercel env vars, leave empty for local dev)
VITE_API_BASE_URL=""
